local Players = game:GetService("Players") -- Fixed typo here
local RunService = game:GetService("RunService")
local ContextActionService = game:GetService("ContextActionService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local me = Players.LocalPlayer
local shotFlags = {}
local isGuarding = false
local guardStartTime = 0
local guardDuration = 1.0

-- Access Roblox's Master Control Module to force the joystick to stay
local PlayerScripts = me:WaitForChild("PlayerScripts")
local PlayerModule = require(PlayerScripts:WaitForChild("PlayerModule"))
local ControlModule = PlayerModule:GetControls()

-- Shooting animation IDs
local shootAnims = {
    95017863158093, 16792383527, 72310933284051, 15933297660,
    15625498058, 15640621238, 137716556823459, 139272202446921,
    15933244201, 15625460755, 15640551795, 115440095914436, 106278649589240
}

local shootAnimSet = {}
for _, id in ipairs(shootAnims) do
    shootAnimSet[id] = true
end

local autoGuardEnabled = true

-- GUI Toggle
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AutoGuardGUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = me:WaitForChild("PlayerGui")

local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 120, 0, 40)
toggleButton.Position = UDim2.new(0.5, -60, 0.8, 0)
toggleButton.BackgroundColor3 = Color3.fromRGB(50,50,50)
toggleButton.TextColor3 = Color3.fromRGB(255,255,255)
toggleButton.Text = "Auto Guard ON"
toggleButton.Parent = screenGui
toggleButton.Active = true
toggleButton.Draggable = true

-- ULTRA SMOOTH GUARD - NO MOVEMENT INTERRUPTION
local function pressGuard()
    if not isGuarding then
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.ButtonL2, false, game)
        isGuarding = true
        guardStartTime = tick()
    end
end

local function releaseGuard()
    if isGuarding then
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.ButtonL2, false, game)
        isGuarding = false
    end
end

toggleButton.MouseButton1Click:Connect(function()
    autoGuardEnabled = not autoGuardEnabled
    toggleButton.Text = autoGuardEnabled and "Auto Guard ON" or "Auto Guard OFF"
    if not autoGuardEnabled and isGuarding then
        releaseGuard()
    end
end)

-- Detect shooting
local function isShooting(plr)
    local char = plr.Character
    if not char then return nil end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end

    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        local animId = tonumber(track.Animation.AnimationId:match("%d+"))
        if animId and shootAnimSet[animId] then
            return animId
        end
    end
    return nil
end

-- Court boundary check
local function isInCourtBounds(hrp, myHRP)
    if not hrp or not myHRP then return false end
    local COURT_LENGTH, COURT_WIDTH = 70, 50
    local minX, maxX = myHRP.Position.X - COURT_WIDTH/2, myHRP.Position.X + COURT_WIDTH/2
    local minZ, maxZ = myHRP.Position.Z - COURT_LENGTH/2, myHRP.Position.Z + COURT_LENGTH/2
    local pos = hrp.Position
    return pos.X >= minX and pos.X <= maxX and pos.Z >= minZ and pos.Z <= maxZ
end

-- MAIN LOOP
RunService.Heartbeat:Connect(function()
    -- FORCE JOYSTICK TO STAY VISIBLE AT ALL COSTS
    if ControlModule then
        ControlModule:Enable(true)
    end

    if not autoGuardEnabled then
        if isGuarding then
            releaseGuard()
        end
        shotFlags = {}
        return
    end

    local myChar = me.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myChar or not myHRP then return end

    -- FAST threat detection
    local shouldGuard = false
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= me and plr.Team ~= me.Team and plr.Character then
            local animId = isShooting(plr)
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if animId and hrp and isInCourtBounds(hrp, myHRP) then
                shouldGuard = true
                shotFlags[plr] = animId
                break
            end
        end
    end

    -- SMOOTH GUARD LOGIC
    if shouldGuard then
        if not isGuarding then
            pressGuard()
        end
        guardStartTime = tick()
    else
        if isGuarding and (tick() - guardStartTime) >= guardDuration then
            releaseGuard()
        end 
    end 
end)
