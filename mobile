-- Visual feedback function for mobile taps
local function toggleGuard()
    autoGuardEnabled = not autoGuardEnabled
    
    local targetColor = autoGuardEnabled and Color3.fromRGB(34, 197, 94) or Color3.fromRGB(239, 68, 68)
    local targetText = autoGuardEnabled and "AUTO: ON" or "AUTO: OFF"
    
    TweenService:Create(toggleButton, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
    toggleButton.Text = targetText
    
    if not autoGuardEnabled and isGuarding then
        releaseGuard()
    end
end

toggleButton.Activated:Connect(toggleGuard)

-- PURE MOBILE REMOTE INTERACTION
-- Fakes the guard status directly via the game's replicated state or network
local function setMobileGuardState(state)
    local char = me.Character
    if not char then return end
    
    -- METHOD A: Fire network remotes if present (Looks for common basketball script patterns)
    local remotes = game:FindFirstChild("RemoteEvent", true) or game:FindFirstChild("RemoteFunction", true)
    
    -- METHOD B: Directly change local character attributes to bypass PC input checks
    char:SetAttribute("Guarding", state)
    char:SetAttribute("Contesting", state)
    char:SetAttribute("Defense", state)
end

function pressGuard()
    if not isGuarding then
        setMobileGuardState(true)
        isGuarding = true
        guardStartTime = tick()
    end
end

function releaseGuard()
    if isGuarding then
        setMobileGuardState(false)
        isGuarding = false
    end
end

-- Track opponent shooting animations
local function isShooting(plr)
    local char = plr.Character
    if not char then return nil end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return nil end

    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
        local animId = tonumber(track.Animation.AnimationId:match("%d+"))
        if animId and shootAnimSet[animId] then
            return animId
        end
    end
    return nil
end

-- Court range check
local function isInCourtBounds(hrp, myHRP)
    if not hrp or not myHRP then return false end
    local COURT_LENGTH, COURT_WIDTH = 70, 50
    local minX, maxX = myHRP.Position.X - COURT_WIDTH/2, myHRP.Position.X + COURT_WIDTH/2
    local minZ, maxZ = myHRP.Position.Z - COURT_LENGTH/2, myHRP.Position.Z + COURT_LENGTH/2
    local pos = hrp.Position
    return pos.X >= minX and pos.X <= maxX and pos.Z >= minZ and pos.Z <= maxZ
end

-- HEARTBEAT MONITOR
RunService.Heartbeat:Connect(function()
    if not autoGuardEnabled then
        if isGuarding then
            releaseGuard()
        end
        shotFlags = {}
        return
    end

    local myChar = me.Character
    local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myChar or not myHRP then return end

    local shouldGuard = false
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= me and plr.Team ~= me.Team and plr.Character then
            local animId = isShooting(plr)
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if animId and hrp and isInCourtBounds(hrp, myHRP) then
                shouldGuard = true
                shotFlags[plr] = animId
                break
            end
        end
    end

    if shouldGuard then
        if not isGuarding then
            pressGuard()
        end
        guardStartTime = tick()
    else
        if isGuarding and (tick() - guardStartTime) >= guardDuration then
            releaseGuard()
        end
    end
end)
